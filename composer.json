{
    "name": "freeplaceholder/laravel",
    "description": "Laravel package with Blade components, directives, Eloquent trait, and helpers for FreePlaceholder.com",
    "keywords": ["placeholder", "avatar", "image", "laravel", "blade", "freeplaceholder"],
    "license": "MIT",
    "authors": [
        {
            "name": "Twenty Miles West",
            "homepage": "https://freeplaceholder.com"
        }
    ],
    "homepage": "https://freeplaceholder.com",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "autoload": {
        "psr-4": {
            "FreePlaceholder\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "FreePlaceholder\\FreePlaceholderServiceProvider"
            ],
            "aliases": {
                "FreePlaceholder": "FreePlaceholder\\Facades\\FreePlaceholder"
            }
        }
    },
    "scripts": {
        "test": "pest --test-directory=tests",
        "test:coverage": "pest --test-directory=tests --coverage"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^10.9 || ^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
